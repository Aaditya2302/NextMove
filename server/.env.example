# Server Config
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/nextmove

# AI Config (NVIDIA NIM, Groq, or OpenAI)
# Use https://api.openai.com/v1 for OpenAI
# Use https://api.groq.com/openai/v1 for Groq
# Use the appropriate NIM endpoint for NVIDIA NIM
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=your_api_key_here

# Models
STT_MODEL=whisper-large-v3
LLM_MODEL=llama3-70b-8192
